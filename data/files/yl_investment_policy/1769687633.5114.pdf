			$(".faq > a").click(function(){
				var $this = $(this);
				setTimeout(function(){
					if ($this.next().is(":visible")) {
						var params = {"event":"gtm_event","event_name":"open_faq","item_name":"[name]","action_type":"open faq","item_type":"open_faq"};
						params['item_name'] = $.trim($this.text());
						
						dataLayer.push(params);
					}
				},500)
			});

			$(".funds-widget .title").click(function(){
