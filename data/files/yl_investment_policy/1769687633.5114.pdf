<main id="content" tabindex="-1" role="main" class="main-page">
	
	<h1 class="sr-only">ילין לפידות בית השקעות</h1>

	
	<div><div class="cover">
	<div class="cover-slider">
					<div>
				<div class="cover-slide" >
					<div class="bg-desktop" style='background-image: url(uploads/n/1690980197.2199.png)'>
											</div>
										<div class="text">
						<div>
															<p class="pre-title ">
																	</p>
																	<p class="larger">
										<strong>
											הפקדה בקליק 										</strong>
									</p>
																		<p class="larger">
										<strong>
											למוצרי הגמל וההשתלמות 										</strong>
									</p>
																	<p class="description">
																	</p>
																	<div>
										<a class="btn btn-primary" href="https://online.yl-invest.co.il/customers/login" target="_blank">
											לביצוע הפקדה דיגיטלית דרך האזור האישי 											<em class="fa fa-angle-left"></em>
										</a>
									</div>
															</div>
					</div>
					<div class="bg-mobile" style='background-image: url(uploads/n/1690974593.2533.png)'>
											</div>
				</div>
			</div>
						<div>
				<div class="cover-slide" >
					<div class="bg-desktop" style='background-image: url(uploads/n/1690980197.2199.png)'>
											</div>
										<div class="text">
						<div>
															<p class="pre-title ">
									מה גורם לאלפי לקוחות<br />
בעלי תיקי השקעות לישון טוב בלילה?								</p>
