			});

			

			$(".cover-slide .video-play").click(function(){
				var params = {"event":"gtm_event","event_name":"play_video","item_name":"סרטון תדמית","action_type":"play video","item_type":"video"};

				dataLayer.push(params);

				setTimeout(function(){
					var myPlayer = document.querySelector('video');
					console.log(myPlayer);
					var percentageCompleted = 0;
					var totalLength;
					var lastPercent = 0;

					myPlayer.ontimeupdate = function() {
						totalLength = myPlayer.duration;   
						percentageCompleted = Math.round((myPlayer.currentTime / totalLength) * 100);
						console.log(totalLength);
						console.log('percentage', (percentageCompleted+'%'));

						if (percentageCompleted == 100 && lastPercent < 100) {
							lastPercent = percentageCompleted;

							var params = {"event":"gtm_event","event_name":"progress_video","item_name":"סרטון תדמית","action_type":"play video","item_type":"video","progress":"100"};
							dataLayer.push(params);
						}
						else if (percentageCompleted == 75 && lastPercent < 75) {
							lastPercent = percentageCompleted;
							var params = {"event":"gtm_event","event_name":"progress_video","item_name":"סרטון תדמית","action_type":"play video","item_type":"video","progress":"75"};
							dataLayer.push(params);
						}
						else if (percentageCompleted == 50 && lastPercent < 50) {
							lastPercent = percentageCompleted;
							var params = {"event":"gtm_event","event_name":"progress_video","item_name":"סרטון תדמית","action_type":"play video","item_type":"video","progress":"50"};
							dataLayer.push(params);
						}
						else if (percentageCompleted == 25 && lastPercent < 25) {
							lastPercent = percentageCompleted;
							var params = {"event":"gtm_event","event_name":"progress_video","item_name":"סרטון תדמית","action_type":"play video","item_type":"video","progress":"25"};
							dataLayer.push(params);
						}
					};
				}, 500);
			});
		</script>


		
