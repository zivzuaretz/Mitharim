			$(".rich-content a").click(function(e){

				var name = $.trim($(this).text());
				var href = $(this).attr("href");
				var ext = href.substring(href.length-3);

				name = name.replace(" נפתח בחלון חדש", "");

				if (ext == "pdf") {
					var params = {"event":"gtm_event","event_name":"pdf_download","item_name":"[name]","action_type":"pdf download","item_type":"form"};
					params['item_name'] = name;
					
					dataLayer.push(params);
				}
			});

			$(".data-layer-load-more").click(function(){
				var params = {"event":"gtm_event","event_name":"click_to_load_more","item_name":"[name]","action_type":"load more","item_type":"[type]"};
				params['item_name'] = $(this).data("item-name");
				params['item_type'] = $(this).data("item-type");

				dataLayer.push(params);
			});

